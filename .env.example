# Domain
DOMAIN=trader-ai.app

# Basic Auth (Caddy)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD_HASH=  # caddy hash-password で生成

# PostgreSQL
POSTGRES_USER=trade
POSTGRES_PASSWORD=
POSTGRES_DB=trader
DATABASE_URL=postgresql://trade:PASSWORD@postgres:5432/trader

# Tiingo (trading)
TIINGO_API_KEY=

# XMTrading MT5 (Windows VPS上のEAで使用、Linux側では不要)
# XM_MT5_LOGIN=
# XM_MT5_PASSWORD=
# XM_MT5_SERVER=

# Finnhub (research)
FINNHUB_API_KEY=

# Claude API (research, analysis)
ANTHROPIC_API_KEY=

# Discord Webhooks
DISCORD_WEBHOOK_ALERT=   # 障害通知（デプロイ失敗・サービス異常）
DISCORD_WEBHOOK_TRADE=   # 取引通知（約定・損切り・利確）
DISCORD_WEBHOOK_MARKET=  # 市場通知（速報分析・価格急変）
