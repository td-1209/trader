# Domain
DOMAIN=trader-ai.app

# Basic Auth (Caddy)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD_HASH=  # caddy hash-password で生成

# PostgreSQL
POSTGRES_USER=trade
POSTGRES_PASSWORD=
POSTGRES_DB=trader
DATABASE_URL=postgresql://trade:PASSWORD@postgres:5432/trader

# Tiingo (trading)
TIINGO_API_KEY=

# MT5 Bridge (trading → Windows VPS)
MT5_BRIDGE_HOST=
MT5_BRIDGE_PORT=5555
XM_MT5_LOGIN=
XM_MT5_PASSWORD=
XM_MT5_SERVER=

# Finnhub (research)
FINNHUB_API_KEY=

# Claude API (research, analysis)
ANTHROPIC_API_KEY=

# Discord Webhook (trading, analysis → notify)
DISCORD_WEBHOOK_URL=
